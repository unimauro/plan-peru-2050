[Unit]
Description=Plan Peru 2050 — secure AI gateway
After=network.target

[Service]
Type=simple
# Usuario efímero sin privilegios (no root): si algo falla, no golpea como root.
DynamicUser=true
ExecStart=/usr/bin/python3 /opt/pp2050-gw/gateway.py
Restart=on-failure
RestartSec=3
# El LLM lo hace ai.tunky.net (la OPENROUTER_KEY vive SOLO allí). Aquí solo un
# X-Client-Token revocable, en archivo aparte 600 (no en el unit, no en el cliente):
#   sudo install -m600 /dev/stdin /etc/pp2050-gw.env <<'EOF'
#   PP2050_AITUNKY_TOKEN=pp2050_...
#   EOF
EnvironmentFile=/etc/pp2050-gw.env
Environment=PP2050_DATA=/var/www/plan-peru-2050/data
Environment=PP2050_GW_PORT=3501
Environment=PP2050_AITUNKY_PROJECT=plan-peru-2050
Environment=PP2050_AITUNKY_ORIGIN=https://planperu2050.pe
# Tope GLOBAL de consultas/día (freno de costo) y orígenes CORS permitidos:
Environment=PP2050_DAILY_MAX=1500
Environment=PP2050_ALLOWED_ORIGINS=https://planperu2050.pe,https://www.planperu2050.pe,https://plan2050.tunky.net
# Hardening
NoNewPrivileges=true
PrivateTmp=true
PrivateDevices=true
ProtectSystem=strict
ProtectHome=true
RestrictAddressFamilies=AF_INET AF_INET6
ReadOnlyPaths=/var/www/plan-peru-2050/data
# Hardening adicional del kernel/syscalls
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictNamespaces=true
RestrictSUIDSGID=true
LockPersonality=true
RestrictRealtime=true
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources
CapabilityBoundingSet=
UMask=0077
# Límites de recursos (techo a los DoS por memoria/threads)
MemoryMax=256M
TasksMax=64
LimitNOFILE=256

[Install]
WantedBy=multi-user.target
