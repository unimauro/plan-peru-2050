# ============================================================
#  Plan Perú 2050 — bloque para tu Caddyfile
#  Sirve el sitio estático + proxy de IA a través del GATEWAY seguro
#  (pp2050-gw en 127.0.0.1:3501). Caddy NO conoce la key ni el modelo:
#  el gateway fija system prompt, modelo, tope de tokens y rate-limit.
#
#  ⚠ NO uses reverse_proxy directo a openrouter.ai con la key en Caddy:
#    eso deja /api/ia como proxy ABIERTO y anónimo pagado con tu key
#    (cualquiera elige modelo caro/max_tokens → factura arbitraria).
#
#  1) Sube el sitio a /var/www/plan-peru-2050  (ver deploy.sh)
#  2) Arranca el gateway (ver deploy/gateway + DEPLOY-VPS.md)
#  3) Pega este bloque en /etc/caddy/Caddyfile (ajusta el dominio)
#  4) sudo systemctl reload caddy
# ============================================================

planperu2050.TU-DOMINIO.pe {
    root * /var/www/plan-peru-2050
    encode zstd gzip

    # --- Proxy de IA → gateway seguro (la key vive SOLO en el unit del gateway) ---
    @ia path /api/ia
    handle @ia {
        # Reescribe cualquier XFF entrante por la IP real del peer (anti-spoof del rate-limit)
        reverse_proxy 127.0.0.1:3501 {
            header_up X-Forwarded-For {remote_host}
        }
    }

    # --- Sitio estático ---
    handle {
        try_files {path} {path}/ /index.html
        file_server
    }

    # Cache largo para assets/datos, no para el HTML
    @static path *.png *.jpg *.svg *.ico *.json *.pdf *.docx *.webmanifest
    header @static Cache-Control "public, max-age=86400"
    header /index.html Cache-Control "no-cache"
}
