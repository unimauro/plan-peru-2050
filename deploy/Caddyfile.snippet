# ============================================================
#  Plan Perú 2050 — bloque para tu Caddyfile
#  Sirve el sitio estático + proxy de IA con la key OCULTA
#  (Caddy inyecta la Authorization desde una variable de entorno;
#   nunca queda en el cliente).
#
#  1) Sube el sitio a /var/www/plan-peru-2050  (ver deploy.sh)
#  2) Pega este bloque en /etc/caddy/Caddyfile (ajusta el dominio)
#  3) Pon la key en el entorno de Caddy (ver DEPLOY-VPS.md)
#  4) sudo systemctl reload caddy
# ============================================================

planperu2050.TU-DOMINIO.pe {
    root * /var/www/plan-peru-2050
    encode zstd gzip

    # --- Proxy de IA (OpenRouter) con key del lado del servidor ---
    @ia path /api/ia
    handle @ia {
        rewrite * /api/v1/chat/completions
        reverse_proxy https://openrouter.ai {
            header_up Host openrouter.ai
            header_up Authorization "Bearer {env.OPENROUTER_KEY}"
            header_up X-Title "Plan Peru 2050"
        }
    }

    # --- Sitio estático ---
    handle {
        try_files {path} {path}/ /index.html
        file_server
    }

    # Cache largo para assets/datos, no para el HTML
    @static path *.png *.jpg *.svg *.ico *.json *.pdf *.docx *.webmanifest
    header @static Cache-Control "public, max-age=86400"
    header /index.html Cache-Control "no-cache"
}
